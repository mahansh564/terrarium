{
  "name": "codeorbit",
  "displayName": "CodeOrbit",
  "description": "A living pixel-art station for AI coding agents inside VS Code.",
  "version": "0.2.0",
  "publisher": "anshulmahajan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anshulmahajan/codeorbit.git"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onCommand:codeorbit.open",
    "onCommand:codeorbit.addAgent",
    "onCommand:codeorbit.resetEcosystem",
    "onCommand:codeorbit.toggleStationEffects",
    "onCommand:codeorbit.toggleAudio",
    "onCommand:codeorbit.cycleSimulationSpeed"
  ],
  "main": "./dist/extension/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeorbit.open",
        "title": "CodeOrbit: Open Station"
      },
      {
        "command": "codeorbit.addAgent",
        "title": "CodeOrbit: Add Agent"
      },
      {
        "command": "codeorbit.resetEcosystem",
        "title": "CodeOrbit: Reset Ecosystem"
      },
      {
        "command": "codeorbit.toggleStationEffects",
        "title": "CodeOrbit: Toggle Station Effects"
      },
      {
        "command": "codeorbit.toggleAudio",
        "title": "CodeOrbit: Toggle Ambient Audio"
      },
      {
        "command": "codeorbit.cycleSimulationSpeed",
        "title": "CodeOrbit: Cycle Simulation Speed"
      }
    ],
    "configuration": {
      "title": "CodeOrbit",
      "properties": {
        "codeorbit.maxFps": {
          "type": "number",
          "default": 30,
          "minimum": 1,
          "maximum": 30,
          "description": "Maximum render FPS for the station webview."
        },
        "codeorbit.stationEffectsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable station environment effects."
        },
        "codeorbit.audioEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable ambient station audio."
        },
        "codeorbit.simulationSpeed": {
          "type": "number",
          "default": 1,
          "enum": [
            0.75,
            1,
            1.25
          ],
          "description": "Simulation speed multiplier for ambient crew and station systems."
        },
        "codeorbit.localMetrics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable local workspace metrics to drive station health."
        },
        "codeorbit.localMetrics.pollMs": {
          "type": "number",
          "default": 20000,
          "minimum": 5000,
          "description": "Polling interval in milliseconds for local project metrics."
        },
        "codeorbit.agents": {
          "type": "array",
          "description": "Configured transcript sources for observed coding agents.",
          "default": [],
          "items": {
            "type": "object",
            "required": [
              "id",
              "name",
              "transcriptPath",
              "crewRole"
            ],
            "additionalProperties": false,
            "properties": {
              "id": {
                "type": "string",
                "description": "Stable agent identifier."
              },
              "name": {
                "type": "string",
                "description": "Display name for the agent."
              },
              "sourceAdapter": {
                "type": "string",
                "description": "Optional source adapter id (for example: jsonl). Defaults to jsonl."
              },
              "transcriptPath": {
                "type": "string",
                "description": "Absolute path to transcript file or directory."
              },
              "crewRole": {
                "type": "string",
                "enum": [
                  "engineer",
                  "pilot",
                  "analyst",
                  "security"
                ],
                "description": "Crew role used in the station."
              },
              "color": {
                "type": "string",
                "description": "Optional hex color override for crew tint."
              }
            }
          }
        },
        "codeorbit.cursorNativeAddAgentBridge.enabled": {
          "type": "boolean",
          "default": true,
          "description": "When running inside Cursor, mirror native add-agent actions into CodeOrbit's add-agent flow."
        },
        "codeorbit.cursorNativeAddAgentBridge.commandIds": {
          "type": "array",
          "default": [
            "glass.newAgent",
            "composer.newAgentChat",
            "composer.createNew",
            "composer.createNewComposerTab"
          ],
          "description": "Cursor command IDs that should trigger CodeOrbit: Add Agent.",
          "items": {
            "type": "string"
          }
        },
        "codeorbit.cursorNativeAddAgentBridge.cooldownMs": {
          "type": "number",
          "default": 1200,
          "minimum": 250,
          "description": "Minimum milliseconds between bridged native Cursor add-agent triggers."
        },
        "codeorbit.cursorNativeAddAgentBridge.storageFallbackEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable deep sync by observing Cursor workspace composer storage for newly created agent sessions."
        },
        "codeorbit.cursorNativeAddAgentBridge.storageFallbackPollMs": {
          "type": "number",
          "default": 1000,
          "minimum": 500,
          "description": "Polling interval in milliseconds for Cursor workspace-storage deep sync and runtime heartbeat streaming."
        }
      }
    }
  },
  "scripts": {
    "build": "npm run typecheck && npm run build:extension && npm run build:webview",
    "build:extension": "esbuild src/extension/activate.ts --bundle --outfile=dist/extension/extension.js --platform=node --format=cjs --target=node18 --sourcemap --external:vscode",
    "build:integration-tests": "esbuild tests/integration/runTest.ts tests/integration/suite/index.ts --bundle --platform=node --format=cjs --outbase=tests/integration --outdir=tests/.build/integration --sourcemap --external:vscode --external:@vscode/test-electron",
    "build:webview": "vite build",
    "release:validate": "node scripts/release-validate.mjs",
    "release:check": "npm run release:validate && npm run typecheck && npm test && npm run package && node scripts/release-validate.mjs --require-vsix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:integration": "npm run build:extension && npm run build:integration-tests && node tests/.build/integration/runTest.js",
    "package": "npm run build && vsce package --no-dependencies"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.96.0",
    "@types/node": "^22.10.2",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.2.2",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.17.0",
    "esbuild": "^0.24.2",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
